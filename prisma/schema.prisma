generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Supporter {
  id                String             @id @default(cuid())
  name              String
  email             String?
  phone             String?
  category          String
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  donations         Donation[]
  prayerCommitments PrayerCommitment[]
}

model Donation {
  id          String    @id @default(cuid())
  supporterId String
  amount      Float
  date        DateTime  @default(now())
  notes       String?
  supporter   Supporter @relation(fields: [supporterId], references: [id], onDelete: Cascade)
}

model PrayerCommitment {
  id          String    @id @default(cuid())
  supporterId String
  frequency   String
  dayOfWeek   String?
  notes       String?
  supporter   Supporter @relation(fields: [supporterId], references: [id], onDelete: Cascade)
}

model User {
  id        String   @id
  email     String   @unique
  password  String
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime
}
